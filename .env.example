# ============================================================
# Application Configuration
# ============================================================

APP_NAME=Enterprise AI Invoice Intelligence Platform
APP_ENV=development
APP_DEBUG=true

# ============================================================
# Backend API Configuration
# ============================================================

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ============================================================
# Database Configuration
# ============================================================
# MVP starts with SQLite.
# Later production version can use PostgreSQL.

DATABASE_URL=sqlite:///./invoice_platform.db

# ============================================================
# AI Provider Configuration
# ============================================================
# Do not put real API keys here.
# Real keys will go into local .env file only.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# ============================================================
# Security / Authentication Configuration
# ============================================================

JWT_SECRET_KEY=change_this_secret_key
JWT_ALGORITHM=HS256

# ============================================================
# File Upload Configuration
# ============================================================

UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=10

# ============================================================
# AI Token / Cost Tracking
# ============================================================

ENABLE_TOKEN_TRACKING=true